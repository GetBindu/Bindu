{
  "author": "dassubhojit750075@gmail.com",
  "name": "multilingual-collab-agent-v2",
  "description": "Identity-aware multilingual research and collaboration agent built on Bindu",
  "version": "1.0.0",
  "recreate_keys": false,
  "skills": [
    "skills/research",
    "skills/translate",
    "skills/collaborate"
  ],
  "capabilities": {},
  "agent_trust": "low",
  "debug_mode": false,
  "debug_level": 1,
  "deployment": {
    "url": "http://127.0.0.1:3773",
    "expose": false,
    "protocol_version": "1.0.0",
    "proxy_urls": [
      "127.0.0.1"
    ],
    "cors_origins": [
      "http://127.0.0.1:3773",
      "http://localhost:3773"
    ]
  },
  "num_history_sessions": 5,
  "environment_variables": [
    {
      "key": "OPENROUTER_API_KEY",
      "description": "OpenRouter API key for LLM calls",
      "required": true
    },
    {
      "key": "MEM0_API_KEY",
      "description": "Optional Mem0 API key for persistent memory",
      "required": false
    }
  ]
}
