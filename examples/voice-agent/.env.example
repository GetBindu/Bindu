# Required for voice STT/TTS
VOICE__STT_API_KEY=your-deepgram-api-key
VOICE__TTS_PROVIDER=piper
VOICE__TTS_VOICE_ID=en_US-ryan-high

# Optional fallback TTS (recommended for resiliency)
VOICE__TTS_FALLBACK_PROVIDER=azure
VOICE__AZURE_TTS_API_KEY=your-azure-speech-key
VOICE__AZURE_TTS_REGION=eastus
VOICE__AZURE_TTS_VOICE=en-US-SaraNeural

# If you still use ElevenLabs as primary/fallback:
# VOICE__TTS_API_KEY=your-elevenlabs-api-key

# Optional tuning
VOICE__ENABLED=true
VOICE__STT_MODEL=nova-3
VOICE__STT_LANGUAGE=en
VOICE__TTS_MODEL=piper-local
VOICE__SAMPLE_RATE=16000
VOICE__AUDIO_CHANNELS=1
VOICE__AUDIO_ENCODING=linear16
VOICE__VAD_ENABLED=true
VOICE__ALLOW_INTERRUPTIONS=true
VOICE__SESSION_TIMEOUT=300

# WebSocket session auth (recommended)
VOICE__SESSION_AUTH_REQUIRED=true
VOICE__SESSION_TOKEN_TTL=300

# Optional LLM backend for smarter responses
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_MEMORY_TURNS=4
VOICE_MAX_SENTENCES=2
