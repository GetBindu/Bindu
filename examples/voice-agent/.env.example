# Required for voice STT/TTS
VOICE__STT_API_KEY=your-deepgram-api-key
VOICE__TTS_API_KEY=your-elevenlabs-api-key

# Optional tuning
VOICE__ENABLED=true
VOICE__STT_MODEL=nova-3
VOICE__STT_LANGUAGE=en
VOICE__TTS_VOICE_ID=<VOICE_ID>
VOICE__TTS_MODEL=eleven_turbo_v2_5
VOICE__SAMPLE_RATE=16000
VOICE__AUDIO_CHANNELS=1
VOICE__AUDIO_ENCODING=linear16
VOICE__VAD_ENABLED=true
VOICE__ALLOW_INTERRUPTIONS=true
VOICE__SESSION_TIMEOUT=300

# WebSocket session auth (recommended)
VOICE__SESSION_AUTH_REQUIRED=true
VOICE__SESSION_TOKEN_TTL=300
